# Пример значений для Vite
VITE_FEMALE_DATE=25.10.1990
VITE_FEMALE_TIME=04:00:00am
VITE_MALE_DATE=25.08.1993
VITE_MALE_TIME=22:00:00pm

# Ключ для OpenRouter (пример формата)
# Вариант 1 (проще): вставить ключ прямо сюда.
VITE_OPENROUTER_API_KEY=<openrouter-api-key>

# Docker Compose (случайный хост-порт вместо 5173)
HOST_WEB_PORT=18473
CONTAINER_WEB_PORT=5173

# Вариант 2 (безопаснее): хранить ключ в файле секрета
OPENROUTER_API_KEY_FILE=./secrets/openrouter_api_key

# Подсказка для вайбкодеров:
# 1) Скопируйте этот файл как .env
# 2) Поменяйте VITE_OPENROUTER_API_KEY или создайте secrets/openrouter_api_key
