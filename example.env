# Example Vite defaults for the relationship form
VITE_FEMALE_DATE=25.10.1990
VITE_FEMALE_TIME=04:00:00am
VITE_MALE_DATE=25.08.1993
VITE_MALE_TIME=22:00

# OpenRouter is read on the server / Vite proxy side only.
OPENROUTER_API_KEY=sk-or-v1-<replace-with-real-key>

# Public hostname and TLS settings for Traefik.
APP_HOSTNAME=astro.localhost
TRAEFIK_HTTP_PORT=80
TRAEFIK_HTTPS_PORT=443
TRAEFIK_ACME_EMAIL=admin@example.com
TRAEFIK_CERT_RESOLVER=letsencrypt
TRAEFIK_TRUSTED_IPS=

# CrowdSec / Traefik bouncer.
CROWDSEC_BOUNCER_KEY=replace-with-long-random-string

# Internal Vite dev server port.
CONTAINER_WEB_PORT=5173

# Optional: load the OpenRouter key from a file instead of an env var.
OPENROUTER_API_KEY_FILE=./secrets/openrouter_api_key

# Quick start:
# 1) Copy this file to .env
# 2) Set APP_HOSTNAME and TRAEFIK_ACME_EMAIL
# 3) Replace OPENROUTER_API_KEY and CROWDSEC_BOUNCER_KEY
# 4) Or create secrets/openrouter_api_key
